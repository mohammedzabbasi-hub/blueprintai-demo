# BluePrintAI backend local development example.
# Copy values into your local environment manager or an untracked .env file.
# Never commit real secrets.

APP_ENV=development
DEBUG=true

HOST=127.0.0.1
PORT=8000

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=sqlite:///./blueprintai.db

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

TIKTOK_CLIENT_ID=replace-me
TIKTOK_CLIENT_SECRET=replace-me
TIKTOK_REDIRECT_URI=http://localhost:8000/auth/tiktok/callback
TIKTOK_API_BASE_URL=https://open-api.tiktokglobalshop.com

OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-5.4

# Render backend production environment variables:
# APP_ENV=production
# DEBUG=false
# SECRET_KEY=<strong random secret, do not use this example value>
# DATABASE_URL=<production Postgres connection string>
# CORS_ORIGINS=https://your-vercel-frontend-domain.example
# TIKTOK_CLIENT_ID=<TikTok app client id>
# TIKTOK_CLIENT_SECRET=<TikTok app client secret>
# TIKTOK_REDIRECT_URI=https://your-render-backend-domain.example/auth/tiktok/callback
# OPENAI_API_KEY=<OpenAI API key>
# OPENAI_MODEL=gpt-5.4
#
# Vercel frontend production environment variable:
# VITE_API_BASE_URL=https://your-render-backend-domain.example
